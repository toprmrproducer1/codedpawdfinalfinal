    "faq": {
      "type": "pawd-collection-faq",
      "blocks": {
        "faq_1": {
          "type": "faq_item",
          "settings": {
            "question": "What's the difference between a collar and a harness for dogs?",
            "answer": "<p>A collar is best for dogs that walk calmly and don't pull. A harness distributes pressure across the chest, making it safer for pullers, puppies, and dogs with respiratory or neck issues. We recommend a harness for most dogs during walk training.</p>"
          }
        },
        "faq_2": {
          "type": "faq_item",
          "settings": {
            "question": "How do I measure my dog for a collar or harness?",
            "answer": "<p>For collars, measure around the base of the neck with a soft tape measure and add 2cm for comfort. For harnesses, measure the widest part of the chest (just behind the front legs). Check each product's size guide for exact sizing.</p>"
          }
        },
        "faq_3": {
          "type": "faq_item",
          "settings": {
            "question": "Do you ship internationally from Australia?",
            "answer": "<p>Yes \u2014 we offer free worldwide shipping on every order. Express shipping is also available at checkout for an additional fee. Most Australian orders arrive within 3\u20135 business days. International orders typically arrive within 7\u201314 business days.</p>"
          }
        },
        "faq_4": {
          "type": "faq_item",
          "settings": {
            "question": "What is your return policy?",
            "answer": "<p>We offer free 30-day returns on all non-personalised items. Items must be unworn, unused, and in their original packaging. Personalised items are final sale unless faulty. Contact us to start a return.</p>"
          }
        },
        "faq_5": {
          "type": "faq_item",
          "settings": {
            "question": "Can I buy now and pay later?",
            "answer": "<p>Yes \u2014 we offer Afterpay on all orders. Split your purchase into 4 interest-free payments. Select Afterpay at checkout to get started.</p>"
          }
        }
      },
