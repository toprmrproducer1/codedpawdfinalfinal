{%- liquid
  assign image = block.settings.image
  assign image_width = block.settings.image_width
  assign link = block.settings.link
  assign image_sizes = '|||sizes|||'
-%}

<div
  class="block__image block-padding"
  data-aos="hero"
  data-aos-order="auto"
  data-aos-anchor="#{{ section.id }}"
  {{ block.shopify_attributes }}
  style="--image-width: {{ image_width }}%; --block-padding-bottom: {{ block.settings.padding_bottom }}px;"
>
  {%- if link != blank -%}<a href="{{ link }}">{%- endif -%}
  {%- if image != blank -%}
    {%- render 'image', image: image, sizes: image_sizes, parallax: true, parallax_speed: -1 -%}
  {%- else -%}
    {%- render 'image', placeholder: 'image', parallax: true, parallax_speed: 1 -%}
  {%- endif -%}
  {%- if link != blank -%}</a>{%- endif -%}
</div>

{% schema %}
{
  "name": "Image",
  "tag": null,
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "2000 x 1400px .jpg recommended. [Learn more](http://presidiodev.com/link/broadcast/images)"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Image link"
    },
    {
      "type": "range",
      "id": "image_width",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Width",
      "default": 100
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Bottom",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Image"
    }
  ]
}
{% endschema %}
