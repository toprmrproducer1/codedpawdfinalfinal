{%- comment -%} PAWD Collection Hero Banner {%- endcomment -%}
{{ 'pawd-collection.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign image = section.settings.image
  assign eyebrow = section.settings.eyebrow
  assign show_title = section.settings.show_title
  assign show_description = section.settings.show_description
-%}

<div class="pawd-coll-hero" data-section-id="{{ section.id }}" data-section-type="pawd-collection-hero">
  <div class="pawd-coll-hero-img">
    {%- if image != blank -%}
      {%- render 'image', image: image, width: 2000, sizes: '100vw', cover: true -%}
    {%- else -%}
      <div class="pawd-coll-hero-ph">{{ collection.title | default: 'Collection' }}</div>
    {%- endif -%}
  </div>
  <div class="pawd-coll-hero-overlay"></div>
  <div class="pawd-coll-hero-content">
    {%- if eyebrow != blank -%}
      <div class="pawd-coll-hero-eyebrow">{{ eyebrow }}{% if collection.title != blank %} · {{ collection.title }}{% endif %}</div>
    {%- endif -%}
    {%- if show_title -%}
      <h1 class="pawd-coll-hero-title">{{ collection.title }}</h1>
    {%- endif -%}
    {%- if show_description and collection.description != blank -%}
      <p class="pawd-coll-hero-desc">{{ collection.description | strip_html | truncatewords: 30 }}</p>
    {%- endif -%}
  </div>
</div>

{%- comment -%} Breadcrumb bar — HOME / Collection Title {%- endcomment -%}
<nav class="pawd-coll-bc" aria-label="Breadcrumb">
  <a href="/">Home</a>
  <span>/</span>
  <span class="cur">{{ collection.title }}</span>
</nav>

{%- schema -%}
{
  "name": "PAWD Collection Hero",
  "class": "pawd-coll-hero-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "PAWD Collection"
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show collection title",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show collection description",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "PAWD Collection Hero"
    }
  ]
}
{%- endschema -%}