{% comment %}
  PAWD Lifestyle Strip — 5-column category panels
  Pixel-accurate conversion from PAWD_Homepage_Mockup_2 v4
{% endcomment %}

<section class="lifestyle">
  {% for block in section.blocks %}
    <a href="{{ block.settings.link }}" class="ls" {{ block.shopify_attributes }}>
      <div class="ls-bg">
        {% if block.settings.image %}
          {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', style: 'width:100%;height:100%;object-fit:cover;' }}
        {% else %}
          <div class="ls-bg-ph">{{ block.settings.title }} editorial</div>
        {% endif %}
      </div>
      <div class="ls-ov"></div>
      <div class="ls-content">
        <div class="ls-title">{{ block.settings.title }}</div>
        <div class="ls-products">{{ block.settings.products_label }}</div>
      </div>
      <div class="ls-arrow"><svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg></div>
    </a>
  {% endfor %}
</section>

<style>
  .lifestyle{display:grid;grid-template-columns:repeat(5,1fr);height:360px}
  .ls{position:relative;overflow:hidden;cursor:pointer;background:#111;border-right:1px solid #0a0a0a;text-decoration:none}.ls:last-child{border-right:none}
  .ls-bg{position:absolute;inset:0;transition:transform .55s var(--ease);display:flex;align-items:center;justify-content:center}.ls:hover .ls-bg{transform:scale(1.06)}
  .ls-bg img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}
  .ls-bg-ph{font-family:var(--fd);font-style:italic;color:rgba(255,255,255,.08);font-size:11px;text-align:center;padding:8px;line-height:1.6}
  .ls-ov{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.82) 0%,rgba(0,0,0,.18) 65%);transition:all .3s var(--ease)}.ls:hover .ls-ov{background:linear-gradient(to top,rgba(0,0,0,.86) 0%,rgba(0,0,0,.28) 65%)}
  .ls-content{position:absolute;bottom:0;left:0;right:0;padding:18px 20px}
  .ls-title{font-family:var(--fd);font-size:clamp(18px,2.2vw,28px);font-weight:300;color:var(--wh);line-height:1;margin-bottom:3px}
  .ls-products{font-family:var(--fb);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.32)}
  .ls-arrow{position:absolute;top:18px;right:18px;width:26px;height:26px;border:1px solid rgba(255,255,255,.18);border-radius:50%;display:flex;align-items:center;justify-content:center;opacity:0;transition:all .25s var(--ease)}.ls-arrow svg{width:10px;height:10px;stroke:var(--wh);fill:none;stroke-width:2}.ls:hover .ls-arrow{opacity:1;border-color:rgba(255,255,255,.42)}
  @media only screen and (max-width:768px){
    .lifestyle{grid-template-columns:repeat(2,1fr);height:auto}
    .ls{min-height:260px}
  }
</style>

{% schema %}
{
  "name": "PAWD Lifestyle Strip",
  "tag": "section",
  "class": "pawd-lifestyle-strip-section",
  "settings": [],
  "blocks": [
    {
      "type": "panel",
      "name": "Panel",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Walk"
        },
        {
          "type": "text",
          "id": "products_label",
          "label": "Products subtitle",
          "default": "Collars · Leads · Harnesses"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PAWD Lifestyle Strip",
      "blocks": [
        { "type": "panel", "settings": { "title": "Walk", "products_label": "Collars · Leads · Harnesses" } },
        { "type": "panel", "settings": { "title": "Play", "products_label": "Toys · Interactive" } },
        { "type": "panel", "settings": { "title": "Sleep", "products_label": "Beds · Bedding" } },
        { "type": "panel", "settings": { "title": "Eat", "products_label": "Bowls · Feeders" } },
        { "type": "panel", "settings": { "title": "Bath", "products_label": "Grooming · Brushes" } }
      ]
    }
  ]
}
{% endschema %}
