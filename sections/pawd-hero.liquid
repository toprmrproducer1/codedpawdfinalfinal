{% comment %}
  PAWD Hero — 2-Slide Carousel
  Pixel-accurate conversion from PAWD_Homepage_Mockup_2 v4
{% endcomment %}

<section class="hero" id="hero-{{ section.id }}">
  <div class="slides-wrap" id="slidesWrap-{{ section.id }}">
    {% for block in section.blocks %}
      <div class="slide" {{ block.shopify_attributes }}>
        {% if block.settings.image %}
          <div style="position:absolute;inset:0;">
            {{ block.settings.image | image_url: width: 2400 | image_tag: loading: 'lazy', style: 'width:100%;height:100%;object-fit:cover;' }}
          </div>
        {% else %}
          <div class="slide-ph">
            <div>
              <div class="ph-big">AI Hero · Slide {{ forloop.index }}<br>Collection Editorial</div>
              <small>Upload a hero image in the theme editor</small>
            </div>
          </div>
        {% endif %}
        <div class="slide-vignette"></div>
        <div class="slide-content">
          {% if block.settings.eyebrow != blank %}
            <span class="slide-eyebrow">{{ block.settings.eyebrow }}</span>
          {% endif %}
          <h1 class="slide-hl">{{ block.settings.heading }}</h1>
          {% if block.settings.subheading != blank %}
            <span class="slide-sub">{{ block.settings.subheading }}</span>
          {% endif %}
          {% if block.settings.button_text != blank %}
            <a href="{{ block.settings.button_link }}" class="slide-cta">{{ block.settings.button_text }} <svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>

  <!-- Carousel nav -->
  {% if section.blocks.size > 1 %}
    <button class="carousel-prev" aria-label="Previous slide"><svg viewBox="0 0 24 24"><path d="M15 18l-6-6 6-6"/></svg></button>
    <button class="carousel-next" aria-label="Next slide"><svg viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg></button>
    <div class="carousel-dots">
      {% for block in section.blocks %}
        <button class="dot{% if forloop.first %} active{% endif %}" aria-label="Slide {{ forloop.index }}"></button>
      {% endfor %}
    </div>
  {% endif %}
</section>

<style>
  .hero{position:relative;height:calc(100vh - 108px);min-height:580px;overflow:hidden;background:var(--ch)}
  .slides-wrap{display:flex;height:100%;transition:transform .85s cubic-bezier(.77,0,.175,1)}
  .slide{min-width:100%;height:100%;position:relative;flex-shrink:0}
  .slide-ph{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;text-align:center;background:linear-gradient(135deg,#141414 0%,#282828 40%,#1a1a1a 100%)}
  .slide-ph .ph-big{font-family:var(--fd);font-size:clamp(28px,4vw,52px);font-weight:300;font-style:italic;color:rgba(255,255,255,.12);line-height:1.1;margin-bottom:10px}
  .slide-ph small{font-family:var(--fb);font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:rgba(255,255,255,.08)}
  .slide-vignette{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.72) 0%,rgba(0,0,0,.06) 45%,transparent 72%)}
  .slide-content{position:absolute;bottom:0;left:0;right:0;padding:0 72px 72px;max-width:1400px;margin:0 auto}
  .slide-eyebrow{font-family:var(--fb);font-size:10px;font-weight:500;letter-spacing:.26em;text-transform:uppercase;color:rgba(255,255,255,.4);margin-bottom:14px;display:block}
  .slide-hl{font-family:var(--fd);font-size:clamp(50px,7vw,90px);font-weight:300;line-height:1.0;color:var(--wh);margin-bottom:10px}
  .slide-hl em{font-style:italic}
  .slide-sub{font-family:var(--fd);font-size:clamp(14px,1.5vw,18px);font-style:italic;color:rgba(255,255,255,.52);margin-bottom:34px;display:block}
  .slide-cta{display:inline-flex;align-items:center;gap:12px;border:1px solid rgba(255,255,255,.42);color:var(--wh);font-family:var(--fb);font-size:11px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;padding:13px 28px;text-decoration:none;transition:all .3s var(--ease)}
  .slide-cta:hover{background:rgba(255,255,255,.08);border-color:rgba(255,255,255,.72)}
  .slide-cta svg{width:14px;height:14px;stroke:currentColor;fill:none;stroke-width:2;transition:transform .25s var(--ease)}
  .slide-cta:hover svg{transform:translateX(4px)}
  .carousel-dots{position:absolute;bottom:28px;left:50%;transform:translateX(-50%);display:flex;gap:8px;z-index:10}
  .dot{width:24px;height:2px;background:rgba(255,255,255,.28);cursor:pointer;transition:all .3s var(--ease);border:none;padding:0}
  .dot.active{background:rgba(255,255,255,.75);width:40px}
  .carousel-prev,.carousel-next{position:absolute;top:50%;transform:translateY(-50%);background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.16);color:var(--wh);width:44px;height:44px;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .25s var(--ease);z-index:10;backdrop-filter:blur(4px);border-radius:0}
  .carousel-prev{left:32px}
  .carousel-next{right:32px}
  .carousel-prev:hover,.carousel-next:hover{background:rgba(255,255,255,.18);border-color:rgba(255,255,255,.4)}
  .carousel-prev svg,.carousel-next svg{width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:2}
  @media only screen and (max-width:768px){
    .hero{height:calc(100vh - 80px);min-height:480px}
    .slide-content{padding:0 24px 48px}
  }
</style>

<script>
(function(){
  const id = '{{ section.id }}';
  const wrap = document.getElementById('slidesWrap-'+id);
  const hero = document.getElementById('hero-'+id);
  if(!wrap||!hero) return;
  const dots = hero.querySelectorAll('.dot');
  const total = {{ section.blocks.size }};
  let current = 0;
  let timer;
  function go(n){
    current = ((n % total) + total) % total;
    wrap.style.transform = 'translateX(-'+current*100+'%)';
    dots.forEach(function(d,i){d.classList.toggle('active',i===current)});
  }
  function next(){go(current+1);reset();}
  function prev(){go(current-1);reset();}
  function reset(){clearInterval(timer);timer=setInterval(next,{{ section.settings.autoplay_speed | times: 1000 | default: 6000 }});}
  hero.querySelector('.carousel-next')?.addEventListener('click',next);
  hero.querySelector('.carousel-prev')?.addEventListener('click',prev);
  dots.forEach(function(d,i){d.addEventListener('click',function(){go(i);reset()})});
  {% if section.settings.autoplay %}timer=setInterval(next,{{ section.settings.autoplay_speed | times: 1000 | default: 6000 }});{% endif %}
})();
</script>

{% schema %}
{
  "name": "PAWD Hero",
  "tag": "section",
  "class": "pawd-hero-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Autoplay speed (seconds)",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 6
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background Image"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow",
          "default": "Premium pet accessories"
        },
        {
          "type": "html",
          "id": "heading",
          "label": "Heading (HTML allowed)",
          "default": "For the Pet<br>Who <em>Deserves</em> More."
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading",
          "default": "Leather collars & harnesses, crafted with intention."
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "Shop the Walk Collection"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PAWD Hero",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "eyebrow": "Premium pet accessories",
            "heading": "For the Pet<br>Who <em>Deserves</em> More.",
            "subheading": "Leather collars & harnesses, crafted with intention.",
            "button_text": "Shop the Walk Collection"
          }
        },
        {
          "type": "slide",
          "settings": {
            "eyebrow": "Play · Sleep · Discover",
            "heading": "Life's Too Short<br>for <em>Boring Toys.</em>",
            "subheading": "Beds they'll never leave. Toys they'll never tire of.",
            "button_text": "Explore Play & Sleep"
          }
        }
      ]
    }
  ]
}
{% endschema %}
