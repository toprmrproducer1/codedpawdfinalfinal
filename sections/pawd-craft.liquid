{% comment %}
  PAWD Our Craft — Pixel-accurate from PAWD_Info_Pages_2
  Manifesto · Materials · Process · Non-Negotiables · Supply Chain · Closing
{% endcomment %}

<style>
.pg-hero.dark{background:var(--ob);border-bottom-color:rgba(255,255,255,.06)}
.pg-hero.dark .pg-hero-eyebrow{color:rgba(255,255,255,.3)}
.pg-hero.dark .pg-hero-title{color:var(--wh)}
.pg-hero.dark .pg-hero-sub{color:rgba(255,255,255,.45)}
.iph{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:7px;text-align:center;padding:20px}
.iph-l{font-family:var(--fb);font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:rgba(255,255,255,.35)}
.iph-s{font-family:var(--fd);font-size:13px;font-style:italic;color:rgba(255,255,255,.18);max-width:240px;line-height:1.5}
.g-a{background:linear-gradient(165deg,#1a1208,#0e0c08,#080808)}
.g-b{background:linear-gradient(165deg,#0e100a,#0a0e0a,#080808)}
.g-d{background:linear-gradient(145deg,#0a1010,#080c0c)}
.g-e{background:linear-gradient(145deg,#14100a,#0e0a06)}
.g-f{background:linear-gradient(145deg,#101418,#0a0e14)}
.g-j{background:linear-gradient(145deg,#0c1410,#081008)}
.g-k{background:linear-gradient(145deg,#101410,#0a0e0a)}
.btn-w{background:var(--wh);color:var(--ob);border:none;padding:15px 36px;font-family:var(--fb);font-size:11px;font-weight:500;letter-spacing:.18em;text-transform:uppercase;cursor:pointer;text-decoration:none;display:inline-block}
</style>

<!-- DARK HERO -->
<div class="pg-hero dark">
  <div class="pg-breadcrumb" style="color:rgba(255,255,255,.3)"><a href="/" style="color:rgba(255,255,255,.3)">Home</a><span>/</span><span style="color:rgba(255,255,255,.6)">Our Craft</span></div>
  <div class="pg-hero-eyebrow" style="display:flex;align-items:center;gap:14px"><span style="display:block;width:28px;height:1px;background:rgba(255,255,255,.3)"></span>{{ section.settings.hero_eyebrow }}</div>
  <div class="pg-hero-title">{{ section.settings.hero_title }}</div>
  <div class="pg-hero-sub">{{ section.settings.hero_subtitle }}</div>
</div>

<!-- MANIFESTO -->
<div style="padding:100px 80px;display:grid;grid-template-columns:1fr 1fr;gap:100px;align-items:start;border-bottom:1px solid var(--sm)">
  <div>
    <div class="section-eyebrow">{{ section.settings.manifesto_eyebrow }}</div>
    <div class="section-title">{{ section.settings.manifesto_title }}</div>
    <div style="font-family:var(--fd);font-size:21px;font-style:italic;font-weight:300;color:var(--ob);line-height:1.4;padding:32px 0;border-top:1px solid var(--sm);border-bottom:1px solid var(--sm);margin:32px 0">{{ section.settings.manifesto_quote }}</div>
    {% if section.settings.manifesto_btn_text != blank %}
      <a href="{{ section.settings.manifesto_btn_url }}" class="btn-d" style="text-decoration:none">{{ section.settings.manifesto_btn_text }}</a>
    {% endif %}
  </div>
  <div>
    <div class="body-text">{{ section.settings.manifesto_p1 }}</div>
    <div class="body-text">{{ section.settings.manifesto_p2 }}</div>
    <div class="body-text">{{ section.settings.manifesto_p3 }}</div>
    <div class="body-text">{{ section.settings.manifesto_p4 }}</div>
    <div style="position:relative;aspect-ratio:4/5;overflow:hidden;margin-top:32px" class="g-d">
      {% if section.settings.manifesto_image %}
        {{ section.settings.manifesto_image | image_url: width: 1200 | image_tag: loading: 'lazy', style: 'width:100%;height:100%;object-fit:cover;' }}
      {% else %}
        <div class="iph"><div class="iph-l">← AI Image Placement</div><div class="iph-s">Workshop interior — leather goods, tools, natural materials on a bench, warm overhead light</div></div>
      {% endif %}
    </div>
  </div>
</div>

<!-- MATERIALS -->
<div style="background:var(--ob);overflow:hidden">
  <div style="padding:80px 80px 60px">
    <div style="font-family:var(--fb);font-size:10px;font-weight:500;letter-spacing:.24em;text-transform:uppercase;color:rgba(255,255,255,.3);margin-bottom:14px">{{ section.settings.materials_eyebrow }}</div>
    <div style="font-family:var(--fd);font-size:clamp(38px,4.5vw,62px);font-weight:300;line-height:1.0;color:var(--wh);max-width:660px;margin-bottom:20px">{{ section.settings.materials_title }}</div>
    <div style="font-family:var(--fb);font-size:13.5px;color:rgba(255,255,255,.38);line-height:1.85;max-width:560px">{{ section.settings.materials_intro }}</div>
  </div>
  <div style="display:grid;grid-template-columns:repeat(4,1fr);border-top:1px solid rgba(255,255,255,.06)">
    {% for block in section.blocks %}
      {% if block.type == 'material' %}
        <div style="padding:44px 38px 52px;{% unless forloop.last %}border-right:1px solid rgba(255,255,255,.06);{% endunless %}" {{ block.shopify_attributes }}>
          <div style="font-size:26px;margin-bottom:26px;opacity:.3">{{ block.settings.flag }}</div>
          <div style="font-family:var(--fd);font-size:24px;font-weight:300;color:var(--wh);margin-bottom:5px">{{ block.settings.title }}</div>
          <div style="font-family:var(--fb);font-size:10px;font-weight:500;letter-spacing:.18em;text-transform:uppercase;color:rgba(255,255,255,.22);margin-bottom:18px">{{ block.settings.source }}</div>
          <div style="font-family:var(--fb);font-size:13px;color:rgba(255,255,255,.38);line-height:1.8;margin-bottom:16px">{{ block.settings.description }}</div>
          <div style="font-family:var(--fd);font-size:13px;font-style:italic;color:rgba(255,255,255,.2)">{{ block.settings.used_in }}</div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

<!-- PROCESS -->
<div style="padding:100px 0;overflow:hidden">
  <div style="padding:0 80px 72px">
    <div class="section-eyebrow">{{ section.settings.process_eyebrow }}</div>
    <div style="font-family:var(--fd);font-size:clamp(34px,4vw,54px);font-weight:300;line-height:1.0;margin-bottom:14px">{{ section.settings.process_title }}</div>
    <div style="font-family:var(--fb);font-size:13.5px;color:var(--st);line-height:1.8;max-width:560px">{{ section.settings.process_intro }}</div>
  </div>
  <div style="display:grid;grid-template-columns:repeat(4,1fr);padding:0 80px">
    {% for block in section.blocks %}
      {% if block.type == 'process_step' %}
        <div style="padding-top:44px;{% unless forloop.last %}padding-right:44px;{% endunless %}border-top:2px solid var(--ob)" {{ block.shopify_attributes }}>
          <div style="font-family:var(--fd);font-size:76px;font-weight:300;color:var(--sm);line-height:1;margin-bottom:18px">{{ block.settings.number }}</div>
          <div style="font-family:var(--fd);font-size:22px;font-weight:400;margin-bottom:11px">{{ block.settings.title }}</div>
          <div style="font-family:var(--fb);font-size:13px;color:var(--st);line-height:1.8;margin-bottom:22px">{{ block.settings.description }}</div>
          <div style="position:relative;aspect-ratio:4/3;overflow:hidden" class="{{ block.settings.gradient }}">
            {% if block.settings.image %}
              {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', style: 'width:100%;height:100%;object-fit:cover;' }}
            {% else %}
              <div class="iph"><div class="iph-l">AI Image</div><div class="iph-s">{{ block.settings.image_hint }}</div></div>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <!-- Process image row -->
  <div style="display:grid;grid-template-columns:1.4fr 1fr 1fr;height:460px;margin-top:72px">
    {% for block in section.blocks %}
      {% if block.type == 'process_image' %}
        <div style="position:relative;overflow:hidden" class="{{ block.settings.gradient }}" {{ block.shopify_attributes }}>
          {% if block.settings.image %}
            {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', style: 'width:100%;height:100%;object-fit:cover;' }}
          {% else %}
            <div class="iph"><div class="iph-l">← AI Image Placement</div><div class="iph-s">{{ block.settings.image_hint }}</div></div>
          {% endif %}
          {% if block.settings.caption != blank %}
            <div style="position:absolute;bottom:20px;left:24px;font-family:var(--fb);font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:rgba(255,255,255,.45);z-index:2">{{ block.settings.caption }}</div>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

<!-- NON-NEGOTIABLES -->
<div style="padding:100px 80px;background:var(--ow)">
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:80px;margin-bottom:72px;align-items:end">
    <div>
      <div class="section-eyebrow">{{ section.settings.nonneg_eyebrow }}</div>
      <div style="font-family:var(--fd);font-size:clamp(32px,3.5vw,50px);font-weight:300;line-height:1.05">{{ section.settings.nonneg_title }}</div>
    </div>
    <div style="font-family:var(--fb);font-size:13.5px;color:var(--gr);line-height:1.85">{{ section.settings.nonneg_intro }}</div>
  </div>
  <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:2px">
    {% for block in section.blocks %}
      {% if block.type == 'commitment' %}
        <div style="background:var(--wh);padding:44px 40px;display:flex;gap:24px;align-items:flex-start" {{ block.shopify_attributes }}>
          <div style="width:30px;height:30px;flex-shrink:0;border:1px solid var(--ob);display:flex;align-items:center;justify-content:center;font-size:12px;margin-top:4px">✓</div>
          <div>
            <div style="font-family:var(--fd);font-size:22px;font-weight:300;margin-bottom:8px">{{ block.settings.title }}</div>
            <div style="font-family:var(--fb);font-size:13px;color:var(--st);line-height:1.8">{{ block.settings.description }}</div>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

<!-- SUPPLY CHAIN -->
<div style="display:grid;grid-template-columns:1fr 1fr;min-height:600px">
  <div style="position:relative;overflow:hidden" class="g-k">
    {% if section.settings.supply_image %}
      {{ section.settings.supply_image | image_url: width: 1200 | image_tag: loading: 'lazy', style: 'width:100%;height:100%;object-fit:cover;' }}
    {% else %}
      <div class="iph"><div class="iph-l">← AI Image Placement</div><div class="iph-s">Supplier workshop — artisan environment, raw materials visible, honest and warm</div></div>
    {% endif %}
  </div>
  <div style="padding:80px;display:flex;flex-direction:column;justify-content:center;background:var(--ch);color:var(--wh)">
    <div style="font-family:var(--fb);font-size:10px;font-weight:500;letter-spacing:.24em;text-transform:uppercase;color:rgba(255,255,255,.3);margin-bottom:18px">{{ section.settings.supply_eyebrow }}</div>
    <div style="font-family:var(--fd);font-size:clamp(28px,2.8vw,42px);font-weight:300;line-height:1.1;margin-bottom:22px">{{ section.settings.supply_title }}</div>
    <div style="font-family:var(--fb);font-size:13.5px;color:rgba(255,255,255,.48);line-height:1.85;margin-bottom:14px">{{ section.settings.supply_p1 }}</div>
    <div style="font-family:var(--fb);font-size:13.5px;color:rgba(255,255,255,.48);line-height:1.85;margin-bottom:14px">{{ section.settings.supply_p2 }}</div>
    <div style="margin-top:32px;border-top:1px solid rgba(255,255,255,.08)">
      {% for block in section.blocks %}
        {% if block.type == 'supply_stat' %}
          <div style="display:flex;justify-content:space-between;align-items:center;padding:14px 0;border-bottom:1px solid rgba(255,255,255,.08)" {{ block.shopify_attributes }}>
            <span style="font-family:var(--fb);font-size:12px;color:rgba(255,255,255,.32)">{{ block.settings.label }}</span>
            <span style="font-family:var(--fd);font-size:18px;font-weight:300;color:var(--wh)">{{ block.settings.value }}</span>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

<!-- CLOSING -->
<div style="padding:120px 80px;text-align:center;background:var(--wh)">
  <div class="section-eyebrow">{{ section.settings.closing_eyebrow }}</div>
  <div style="font-family:var(--fd);font-size:clamp(34px,4.5vw,64px);font-weight:300;line-height:1.1;max-width:820px;margin:0 auto 16px">{{ section.settings.closing_title }}</div>
  <div style="font-family:var(--fb);font-size:13.5px;color:var(--gr);line-height:1.85;max-width:560px;margin:0 auto 36px">{{ section.settings.closing_sub }}</div>
  <div style="display:inline-flex;gap:16px;margin-bottom:72px">
    {% if section.settings.closing_btn1_text != blank %}
      <a href="{{ section.settings.closing_btn1_url }}" class="btn-d" style="text-decoration:none">{{ section.settings.closing_btn1_text }}</a>
    {% endif %}
    {% if section.settings.closing_btn2_text != blank %}
      <a href="{{ section.settings.closing_btn2_url }}" class="btn-g" style="text-decoration:none">{{ section.settings.closing_btn2_text }}</a>
    {% endif %}
  </div>
  <div style="display:grid;grid-template-columns:1fr 1fr;height:400px;gap:2px">
    <div style="position:relative;overflow:hidden" class="g-a">
      {% if section.settings.closing_img1 %}
        {{ section.settings.closing_img1 | image_url: width: 1200 | image_tag: loading: 'lazy', style: 'width:100%;height:100%;object-fit:cover;' }}
      {% else %}
        <div class="iph"><div class="iph-l">← AI Image Placement</div><div class="iph-s">Dog wearing a PAWD collar — close lifestyle shot, golden hour light</div></div>
      {% endif %}
    </div>
    <div style="position:relative;overflow:hidden" class="g-b">
      {% if section.settings.closing_img2 %}
        {{ section.settings.closing_img2 | image_url: width: 1200 | image_tag: loading: 'lazy', style: 'width:100%;height:100%;object-fit:cover;' }}
      {% else %}
        <div class="iph"><div class="iph-l">← AI Image Placement</div><div class="iph-s">Cat wearing a PAWD collar — at home, soft window light</div></div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "PAWD Our Craft",
  "tag": "section",
  "class": "pawd-craft-section",
  "settings": [
    { "type": "header", "content": "Hero" },
    { "type": "text", "id": "hero_eyebrow", "label": "Eyebrow", "default": "The Standard We Hold Ourselves To" },
    { "type": "html", "id": "hero_title", "label": "Title (HTML)", "default": "Our<br><em>Craft.</em>" },
    { "type": "textarea", "id": "hero_subtitle", "label": "Subtitle", "default": "The materials we choose. The people who make them. The process that turns raw goods into something your pet wears every day of their life." },

    { "type": "header", "content": "Manifesto" },
    { "type": "text", "id": "manifesto_eyebrow", "label": "Eyebrow", "default": "The PAWD Standard" },
    { "type": "html", "id": "manifesto_title", "label": "Title (HTML)", "default": "We Don't Make<br><em>Products.</em><br>We Make Things<br>Worth Keeping." },
    { "type": "textarea", "id": "manifesto_quote", "label": "Quote", "default": "\"The difference between a good product and a great one is usually invisible — until it isn't.\"" },
    { "type": "text", "id": "manifesto_btn_text", "label": "Button Text", "default": "Shop the Collection" },
    { "type": "url", "id": "manifesto_btn_url", "label": "Button Link" },
    { "type": "textarea", "id": "manifesto_p1", "label": "Paragraph 1", "default": "At PAWD, every product starts with one question: would we buy this for our own dog? Not \"is it good enough for the market\" — is it good enough for us? That question has killed more product ideas than any spreadsheet ever has." },
    { "type": "textarea", "id": "manifesto_p2", "label": "Paragraph 2", "default": "We're not a volume business. We don't make hundreds of SKUs. We make a considered range of products, each chosen because there was a genuine gap — something missing or chronically underserved in the premium pet market." },
    { "type": "textarea", "id": "manifesto_p3", "label": "Paragraph 3", "default": "Everything we sell has been through at least twelve months of development before it reaches the site. Materials are sourced first, then designs are built around what the material can do — not the reverse." },
    { "type": "textarea", "id": "manifesto_p4", "label": "Paragraph 4", "default": "That process is slower and more expensive than how most pet accessories are made. We've accepted that. Because the alternative — fast, cheap, disposable — is exactly the problem we started PAWD to solve." },
    { "type": "image_picker", "id": "manifesto_image", "label": "Workshop Image" },

    { "type": "header", "content": "Materials Section" },
    { "type": "text", "id": "materials_eyebrow", "label": "Eyebrow", "default": "What We Work With" },
    { "type": "html", "id": "materials_title", "label": "Title (HTML)", "default": "Materials Chosen<br>for <em style='font-style:italic;color:rgba(255,255,255,.4)'>Longevity.</em>" },
    { "type": "textarea", "id": "materials_intro", "label": "Intro", "default": "We don't specify materials based on cost. We specify them based on what they do over time — how they age, how they perform, what they feel like after two years of daily wear." },

    { "type": "header", "content": "Process Section" },
    { "type": "text", "id": "process_eyebrow", "label": "Eyebrow", "default": "How It's Made" },
    { "type": "html", "id": "process_title", "label": "Title (HTML)", "default": "Twelve Months<br>Before It Reaches You." },
    { "type": "textarea", "id": "process_intro", "label": "Intro", "default": "Every product in the PAWD range follows the same development process. It's not the fastest way to build a range. It is the only way we know how to build one we're proud of." },

    { "type": "header", "content": "Non-Negotiables" },
    { "type": "text", "id": "nonneg_eyebrow", "label": "Eyebrow", "default": "Our Non-Negotiables" },
    { "type": "html", "id": "nonneg_title", "label": "Title (HTML)", "default": "The Things We<br>Won't Compromise On." },
    { "type": "textarea", "id": "nonneg_intro", "label": "Intro", "default": "These aren't aspirations or marketing claims. They're specific commitments we've made about how PAWD products are made and what they're made from." },

    { "type": "header", "content": "Supply Chain" },
    { "type": "image_picker", "id": "supply_image", "label": "Supply Chain Image" },
    { "type": "text", "id": "supply_eyebrow", "label": "Eyebrow", "default": "Supply Chain Transparency" },
    { "type": "html", "id": "supply_title", "label": "Title (HTML)", "default": "We Know Everyone<br>Who Makes <em style='font-style:italic'>Our Products.</em><br>By Name." },
    { "type": "textarea", "id": "supply_p1", "label": "Paragraph 1", "default": "PAWD operates a fully traceable supply chain. We work with nine suppliers across four countries — all visited in person, all in long-term relationships rather than spot orders." },
    { "type": "textarea", "id": "supply_p2", "label": "Paragraph 2", "default": "We don't use sourcing agents or intermediaries. When a supplier's capacity fills up, we wait. We don't move production to an unknown factory to meet a deadline." },

    { "type": "header", "content": "Closing Section" },
    { "type": "text", "id": "closing_eyebrow", "label": "Eyebrow", "default": "The End Result" },
    { "type": "html", "id": "closing_title", "label": "Title (HTML)", "default": "Products Made to Be<br><em style='font-style:italic;color:var(--st)'>Worn Every Day.</em><br>For Years." },
    { "type": "textarea", "id": "closing_sub", "label": "Subtitle", "default": "Every decision in the PAWD supply chain — material, supplier, process, hardware — is made with one animal in mind: the one who'll wear it." },
    { "type": "text", "id": "closing_btn1_text", "label": "Button 1 Text", "default": "Shop the Collection" },
    { "type": "url", "id": "closing_btn1_url", "label": "Button 1 Link" },
    { "type": "text", "id": "closing_btn2_text", "label": "Button 2 Text", "default": "Read Our Story" },
    { "type": "url", "id": "closing_btn2_url", "label": "Button 2 Link" },
    { "type": "image_picker", "id": "closing_img1", "label": "Closing Image 1 (Dog)" },
    { "type": "image_picker", "id": "closing_img2", "label": "Closing Image 2 (Cat)" }
  ],
  "blocks": [
    {
      "type": "material",
      "name": "Material Card",
      "settings": [
        { "type": "text", "id": "flag", "label": "Flag Emoji", "default": "🇮🇹" },
        { "type": "text", "id": "title", "label": "Title", "default": "Full-Grain Leather" },
        { "type": "text", "id": "source", "label": "Source Line", "default": "Sourced · Veneto, Italy" },
        { "type": "textarea", "id": "description", "label": "Description" },
        { "type": "text", "id": "used_in", "label": "Used In", "default": "Used in: Leather Collars, Leads, Harness Sets" }
      ]
    },
    {
      "type": "process_step",
      "name": "Process Step",
      "settings": [
        { "type": "text", "id": "number", "label": "Step Number", "default": "01" },
        { "type": "text", "id": "title", "label": "Title", "default": "Material First" },
        { "type": "textarea", "id": "description", "label": "Description" },
        { "type": "image_picker", "id": "image", "label": "Step Image" },
        { "type": "text", "id": "image_hint", "label": "Image Placeholder Text", "default": "Step image description" },
        { "type": "text", "id": "gradient", "label": "Placeholder Gradient Class", "default": "g-e" }
      ]
    },
    {
      "type": "process_image",
      "name": "Process Row Image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "image_hint", "label": "Image Placeholder Text" },
        { "type": "text", "id": "caption", "label": "Caption Overlay" },
        { "type": "text", "id": "gradient", "label": "Placeholder Gradient Class", "default": "g-a" }
      ]
    },
    {
      "type": "commitment",
      "name": "Non-Negotiable",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "No Split Leather, Ever" },
        { "type": "textarea", "id": "description", "label": "Description" }
      ]
    },
    {
      "type": "supply_stat",
      "name": "Supply Chain Stat",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Active Suppliers" },
        { "type": "text", "id": "value", "label": "Value", "default": "9 partners" }
      ]
    }
  ],
  "presets": [
    {
      "name": "PAWD Our Craft",
      "blocks": [
        { "type": "material", "settings": { "flag": "🇮🇹", "title": "Full-Grain Leather", "source": "Sourced · Veneto, Italy", "description": "The highest grade of leather — the outermost layer of the hide with the natural grain intact. More expensive, harder to work with, and less uniform than corrected-grain alternatives. The only leather that genuinely improves with age, developing a rich patina unique to each animal.", "used_in": "Used in: Leather Collars, Leads, Harness Sets" } },
