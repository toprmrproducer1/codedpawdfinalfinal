{% comment %}
  PAWD Article Post — Single article layout
  Full-bleed hero · Meta bar · Two-column (post body + sticky sidebar) · Related articles
  Used with article.default.json template
{% endcomment %}

{{ 'pawd-resources.css' | asset_url | stylesheet_tag }}

<!-- Full-bleed hero image -->
<div class="post-hero-img">
  {%- if article.image -%}
    {{ article.image | image_url: width: 2000 | image_tag: loading: 'eager', style: 'width:100%;height:100%;object-fit:cover;position:absolute;inset:0' }}
  {%- else -%}
    <div class="iph" style="height:100%"><div class="iph-l">Article Hero Image</div></div>
  {%- endif -%}
</div>

<!-- Meta bar -->
<div class="post-meta-bar">
  <div class="pg-breadcrumb" style="margin:0">
    <a href="/blogs/resources">Resources</a><span>/</span>
    <a href="/blogs/resources/tagged/articles">Articles</a><span>/</span>
    <span>{{ article.title | truncate: 40 }}</span>
  </div>
  <span class="pmb-sep">&middot;</span>
  <span class="pmb-item">{{ article.content | strip_html | split: ' ' | size | divided_by: 200 | plus: 1 }} min read</span>
  {%- if article.author -%}
    <span class="pmb-sep">&middot;</span>
    <span class="pmb-item">By {{ article.author }}</span>
  {%- endif -%}
  <span class="pmb-sep">&middot;</span>
  <span class="pmb-item">{{ article.published_at | date: '%B %Y' }}</span>
</div>

<!-- Reading progress bar -->
<div class="cb-progress-wrap"><div class="cb-progress-bar" id="articleProgress"></div></div>

<div style="padding:0 80px">
<div class="post-layout">

  <!-- Main body -->
  <div class="post-body">
    <!-- Tags -->
    <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px">
      {%- for tag in article.tags limit: 3 -%}
        <span class="tag tag-{{ tag | handleize }}">{{ tag }}</span>
      {%- endfor -%}
    </div>

    <!-- Title -->
    <h1 class="cb-title">{{ article.title }}</h1>

    <!-- Article content -->
    <div class="art-content">
      {{ article.content }}
    </div>

    <hr class="art-divider">

    <!-- Author bio -->
    {%- if article.author -%}
      <div class="author-block">
        <div class="author-avatar" style="background:var(--ch);display:flex;align-items:center;justify-content:center">
          <span style="font-family:var(--fd);font-size:24px;color:rgba(255,255,255,.25)">{{ article.author | slice: 0 }}</span>
        </div>
        <div class="author-info">
          <div class="author-name">{{ article.author }}</div>
          <div class="author-role">{{ section.settings.author_role }}</div>
        </div>
      </div>
    {%- endif -%}

    <!-- Social share -->
    <div class="cb-social-share">
      <div class="cb-ss-label">Found this useful? Share it.</div>
      <div class="cb-ss-btns">
        <button class="cb-ss-btn" onclick="window.open('https://www.facebook.com/sharer/sharer.php?u='+encodeURIComponent(window.location.href),'_blank','width=600,height=400')">Share on Facebook</button>
        <button class="cb-ss-btn" onclick="navigator.clipboard.writeText(window.location.href).then(function(){alert('Link copied!')})">Copy Link</button>
      </div>
    </div>

    <!-- Tags footer -->
    {%- if article.tags.size > 0 -%}
      <div class="cb-tags-footer">
        <span class="cb-tags-label">Tags:</span>
        {%- for tag in article.tags -%}
          <a href="{{ blog.url }}/tagged/{{ tag | handleize }}" class="cb-tag-item" style="text-decoration:none">{{ tag }}</a>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  <!-- Sidebar -->
  <div class="post-sidebar">
    <!-- Featured products -->
    {%- for block in section.blocks -%}
      {%- if block.type == 'sidebar_product' -%}
        {%- assign prod = all_products[block.settings.product] -%}
        {%- if prod != blank and forloop.index == 1 -%}
          <div class="sidebar-widget">
            <div class="sw-title">Featured Products</div>
        {%- endif -%}
        {%- if prod != blank -%}
            <a href="{{ prod.url }}" class="sw-product" style="text-decoration:none;color:inherit" {{ block.shopify_attributes }}>
              <div class="sw-prod-img">
                {%- if prod.featured_image -%}
                  {{ prod.featured_image | image_url: width: 120 | image_tag: loading: 'lazy', style: 'width:100%;height:100%;object-fit:cover;position:absolute;inset:0' }}
                {%- endif -%}
              </div>
              <div class="sw-prod-info">
                <div class="sw-prod-name">{{ prod.title }}</div>
                <div class="sw-prod-price">{{ prod.price | money }}</div>
              </div>
            </a>
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}
    {%- assign has_products = false -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'sidebar_product' -%}
        {%- assign has_products = true -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}
    {%- if has_products -%}
          </div>
    {%- endif -%}

    <!-- Related articles -->
    <div class="sidebar-widget">
      <div class="sw-title">Related Articles</div>
      {%- assign articles_blog = blogs['articles'] -%}
      {%- if articles_blog -%}
        {%- for related in articles_blog.articles limit: 3 -%}
          {%- unless related.handle == article.handle -%}
            <a href="{{ related.url }}" class="sw-card" style="text-decoration:none;color:inherit">
              <div class="sw-card-img">
                {%- if related.image -%}
                  {{ related.image | image_url: width: 400 | image_tag: loading: 'lazy', style: 'width:100%;height:100%;object-fit:cover;position:absolute;inset:0' }}
                {%- else -%}
                  <div class="iph"><div class="iph-l" style="font-size:9px">AI Image</div></div>
                {%- endif -%}
              </div>
              <div class="sw-card-body">
                <div class="sw-card-tag">
                  {%- for tag in related.tags limit: 2 -%}
                    {{ tag }}{%- unless forloop.last %} &middot; {% endunless -%}
                  {%- endfor -%}
                </div>
                <div class="sw-card-title">{{ related.title }}</div>
              </div>
            </a>
          {%- endunless -%}
        {%- endfor -%}
      {%- endif -%}
    </div>

    <!-- Newsletter widget -->
    <div class="sidebar-widget" style="background:var(--ob);border-color:var(--ob)">
      <div class="sw-title" style="color:rgba(255,255,255,.4);border-bottom-color:rgba(255,255,255,.1)">Newsletter</div>
      <div style="font-family:var(--fd);font-size:18px;font-weight:300;color:var(--wh);margin-bottom:8px">Stay <em>Updated</em></div>
      <div style="font-family:var(--fb);font-size:12px;color:rgba(255,255,255,.4);line-height:1.6;margin-bottom:14px">New articles and guides, delivered to your inbox.</div>
      {%- form 'customer', id: 'sidebar-newsletter' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input name="contact[email]" type="email" style="width:100%;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);padding:11px 14px;font-family:var(--fb);font-size:13px;color:var(--wh);outline:none;margin-bottom:8px;box-sizing:border-box;color-scheme:dark" placeholder="Your email address" required>
        <button type="submit" class="btn-d" style="width:100%;text-align:center;font-size:10px;padding:11px;background:var(--wh);color:var(--ob)">Subscribe</button>
      {%- endform -%}
    </div>

    <!-- Help callout -->
    <div class="sidebar-widget" style="background:var(--ow)">
      <div style="font-family:var(--fd);font-size:20px;font-weight:300;margin-bottom:8px">Need <em>help?</em></div>
      <div style="font-family:var(--fb);font-size:12px;color:var(--st);line-height:1.65;margin-bottom:14px">{{ section.settings.help_text }}</div>
      <a href="{{ section.settings.help_url | default: '/pages/contact' }}" class="btn-g" style="width:100%;text-align:center;font-size:10px;padding:11px;display:block">Get in Touch</a>
    </div>
  </div>
</div>
</div>

<!-- Related articles strip -->
<div class="related-section">
  <div style="font-family:var(--fb);font-size:10px;font-weight:500;letter-spacing:.24em;text-transform:uppercase;color:var(--si);margin-bottom:8px">{{ section.settings.related_eyebrow }}</div>
  <div style="font-family:var(--fd);font-size:clamp(28px,3vw,42px);font-weight:300">{{ section.settings.related_title }}</div>
  <div class="rel-grid">
    {%- assign rel_blog = blogs['articles'] -%}
    {%- assign rel_count = 0 -%}
    {%- if rel_blog -%}
      {%- for rel_article in rel_blog.articles limit: 6 -%}
        {%- unless rel_article.handle == article.handle -%}
          {%- assign rel_count = rel_count | plus: 1 -%}
          {%- if rel_count <= 3 -%}
            <a href="{{ rel_article.url }}" class="card" style="text-decoration:none;color:inherit">
              <div class="card-img">
                {%- if rel_article.image -%}
                  {{ rel_article.image | image_url: width: 600 | image_tag: loading: 'lazy', style: 'width:100%;height:100%;object-fit:cover;position:absolute;inset:0' }}
                {%- else -%}
                  <div class="iph"><div class="iph-l">AI Image</div></div>
                {%- endif -%}
              </div>
              <div class="card-body">
                <div class="card-tag-row">
                  {%- for tag in rel_article.tags limit: 1 -%}
                    <span class="tag tag-{{ tag | handleize }}">{{ tag }}</span>
                  {%- endfor -%}
                </div>
                <div class="card-title">{{ rel_article.title }}</div>
                <div class="card-excerpt">{{ rel_article.excerpt_or_content | strip_html | truncate: 120 }}</div>
                <div class="card-meta">
                  <span class="read-time">{{ rel_article.content | strip_html | split: ' ' | size | divided_by: 200 | plus: 1 }} min</span>
                  <span class="btn-txt">Read</span>
                </div>
              </div>
            </a>
          {%- endif -%}
        {%- endunless -%}
      {%- endfor -%}
    {%- endif -%}
  </div>
</div>

<script>
  /* Reading progress bar */
  (function() {
    var bar = document.getElementById('articleProgress');
    if (!bar) return;
    window.addEventListener('scroll', function() {
      var h = document.documentElement.scrollHeight - window.innerHeight;
      if (h > 0) bar.style.width = (window.scrollY / h * 100) + '%';
    });
  })();
</script>

{% schema %}
{
  "name": "PAWD Article Post",
  "tag": "section",
  "class": "pawd-article-post-section",
  "settings": [
    { "type": "header", "content": "Author" },
    { "type": "text", "id": "author_role", "label": "Author Role", "default": "Co-Founder · PAWD" },

    { "type": "header", "content": "Sidebar" },
    { "type": "text", "id": "help_text", "label": "Help Widget Text", "default": "Have a question about our materials, sourcing, or products? We're happy to share." },
    { "type": "url", "id": "help_url", "label": "Help Widget Link" },

    { "type": "header", "content": "Related Section" },
    { "type": "text", "id": "related_eyebrow", "label": "Eyebrow", "default": "More From the Journal" },
    { "type": "html", "id": "related_title", "label": "Title", "default": "Related <em>Articles</em>" }
  ],
  "blocks": [
    {
      "type": "sidebar_product",
      "name": "Sidebar Product",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" }
      ]
    }
  ],
  "presets": [
    {
      "name": "PAWD Article Post"
    }
  ]
}
{% endschema %}
