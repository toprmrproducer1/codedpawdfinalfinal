{%- comment -%}
  Shared resources sub-navigation bar.
  Renders a horizontal tab nav used on all resources pages.

  Usage:
    {% render 'pawd-resources-nav', active: 'hub' %}
    {% render 'pawd-resources-nav', active: 'guides' %}
    {% render 'pawd-resources-nav', active: 'articles' %}
{%- endcomment -%}

{%- liquid
  unless active
    assign active = 'hub'
  endunless
-%}

<nav class="res-subnav" aria-label="Resources navigation">
  {%- if active == 'guides' or active == 'articles' -%}
    <a href="/blogs/resources" class="res-snav-item">← All Resources</a>
  {%- endif -%}

  {%- if active == 'hub' -%}
    <a href="/blogs/resources" class="res-snav-item active" aria-current="page">All</a>
    <a href="/blogs/resources/tagged/guides" class="res-snav-item">Guides</a>
    <a href="/blogs/resources/tagged/articles" class="res-snav-item">Articles</a>
    <a href="/blogs/resources/tagged/sizing" class="res-snav-item">Sizing &amp; Fit</a>
    <a href="/blogs/resources/tagged/care" class="res-snav-item">Product Care</a>
    <a href="/blogs/resources/tagged/materials" class="res-snav-item">Materials</a>
    <a href="/blogs/resources/tagged/brand" class="res-snav-item">Our Brand</a>
  {%- elsif active == 'guides' -%}
    <a href="/blogs/resources/tagged/guides" class="res-snav-item{% unless current_tags %} active{% endunless %}"{% unless current_tags %} aria-current="page"{% endunless %}>All Guides</a>
    <a href="/blogs/resources/tagged/sizing" class="res-snav-item{% if current_tags contains 'sizing' %} active{% endif %}">Sizing &amp; Fit</a>
    <a href="/blogs/resources/tagged/care" class="res-snav-item{% if current_tags contains 'care' %} active{% endif %}">Product Care</a>
    <a href="/blogs/resources/tagged/training" class="res-snav-item{% if current_tags contains 'training' %} active{% endif %}">Training</a>
    <a href="/blogs/resources/tagged/cats" class="res-snav-item{% if current_tags contains 'cats' %} active{% endif %}">Cat Guides</a>
  {%- elsif active == 'articles' -%}
    <a href="/blogs/resources/tagged/articles" class="res-snav-item{% unless current_tags %} active{% endunless %}"{% unless current_tags %} aria-current="page"{% endunless %}>All Articles</a>
    <a href="/blogs/resources/tagged/materials" class="res-snav-item{% if current_tags contains 'materials' %} active{% endif %}">Materials &amp; Craft</a>
    <a href="/blogs/resources/tagged/brand" class="res-snav-item{% if current_tags contains 'brand' %} active{% endif %}">Brand Story</a>
    <a href="/blogs/resources/tagged/sustainability" class="res-snav-item{% if current_tags contains 'sustainability' %} active{% endif %}">Sustainability</a>
  {%- endif -%}
</nav>
